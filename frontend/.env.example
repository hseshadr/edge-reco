# Nimbus frontend — environment configuration (EXAMPLE).
#
# Copy to `.env` and edit:    cp .env.example .env
# Vite auto-loads `.env` from this directory at dev/build time. Only VITE_*
# vars are exposed to the browser bundle; the rest are dev/test tooling only.
# Nothing here is a secret.

# ── SPA build/runtime (Vite) ─────────────────────────────────────────────────

# Origin the browser syncs the signed catalog bundle from (the Caddy edge / CDN).
# Read by @edgeproc/browser's configFromEnv() and baked at build time.
#   - `make dev` / docker compose:   http://localhost:8081  (host-mapped Caddy edge)
#   - bare `npm run dev` (no edge):  http://localhost:8080  (the static origin)
VITE_BUNDLE_BASE_URL=http://localhost:8081

# ── Test / dev tooling (NOT exposed to the browser) ──────────────────────────

# Port the Playwright e2e static catalog server (catalog-server.mjs) listens on.
# Defaults: 8910 (engine C1 e2e), 8920 (storefront e2e). Override to avoid clashes.
CATALOG_PORT=8910

# Set to "1" to skip the embedder parity tests (which download the transformers.js
# model on first run). Useful offline or in constrained CI. Default: run them.
EDGE_RECO_SKIP_EMBEDDING_PARITY=
