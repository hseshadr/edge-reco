{
	"name": "frontend",
	"private": true,
	"version": "0.10.1",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"build:pages": "node scripts/build-pages.mjs",
		"lint": "biome check .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:preflight": "node --test scripts/*.test.mjs",
		"test:e2e": "playwright test",
		"test:e2e:offline": "VITE_BUNDLE_BASE_URL=http://localhost:8921/catalog pnpm run build && playwright test -c playwright.offline.config.ts",
		"typecheck": "tsc -b",
		"gen-icons": "node scripts/gen-icons.mjs",
		"preview": "vite preview"
	},
	"dependencies": {
		"@edgeproc/browser": "workspace:*",
		"@hpcc-js/wasm-zstd": "^1.13.0",
		"@huggingface/transformers": "^4.2.0",
		"@noble/ed25519": "^3.1.0",
		"motion": "^12.40.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@playwright/test": "^1.60.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/coverage-v8": "^4.1.9",
		"jsdom": "^29.1.1",
		"sharp": "^0.35.2",
		"typescript": "~6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.8",
		"workbox-window": "7.4.1"
	}
}
