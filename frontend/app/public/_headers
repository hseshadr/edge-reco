# Cloudflare Pages headers. Three concerns:
#   1. A global baseline of security headers (the /* block).
#   2. Freshness for the service worker + manifest so updates propagate fast.
#   3. Immutable caching for release-pinned trust and runtime assets.

# Baseline security headers for every response. The CSP allows the app's known
# runtime edges: local module workers and ONNX WASM. Catalog images use local
# editorial placeholders. Inline scripts stay blocked; the two JSON-LD blocks
# are pinned by hash. Cloudflare Pages adds wildcard CORS to static responses by
# default, but this deployment is same-origin, so detach it here.
/*
  ! Access-Control-Allow-Origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'wasm-unsafe-eval' 'sha256-ST9qnRidkbMTVXZFRJaR0oO2gFOyXRSKcN4rb/4d9yM=' 'sha256-ICu6RKCjCK7Myvbr4Mi9jOiGsH2qBIXyfYYQDNwdOfw='; worker-src 'self' blob:; connect-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; manifest-src 'self'; upgrade-insecure-requests
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), display-capture=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), usb=()

# Keep the service worker and manifest fresh so updates propagate immediately.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

# Generated per deployment; never serve an older source identity from an edge
# cache. The deploy workflow compares its commit to EXPECTED_SHA.
/build.json
  Cache-Control: no-store

# The trust root is intentionally release-pinned. Rotate it only with a new,
# versioned path and an application release; clients must never reinterpret it.
/public.key
  Content-Type: application/octet-stream
  Cache-Control: public, max-age=31536000, immutable

# Signed bundle manifests/chunks are content-addressed. Vite assets and the
# self-hosted model/ORT runtime are sha256-pinned by build preflight, so each
# successful release can cache them without revalidation.
/bundle/chunk/*
  Cache-Control: public, max-age=31536000, immutable
/bundle/manifest/*
  Cache-Control: public, max-age=31536000, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable
/models/*
  Cache-Control: public, max-age=31536000, immutable
/ort/*
  Cache-Control: public, max-age=31536000, immutable
