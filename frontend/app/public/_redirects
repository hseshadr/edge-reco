# Clean URLs for the static entity pages. Cloudflare Pages applies the FIRST
# matching rule, so these specific 200-rewrites MUST come before the SPA
# catch-all below — otherwise /* would swallow them and serve the SPA shell.
/edgeproc   /edgeproc.html   200
/github     /github.html     200
/faq        /faq.html        200

# SPA fallback — keep LAST. Any route not matched above renders the app shell.
/*    /index.html   200
