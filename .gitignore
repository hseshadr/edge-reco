# Bundle signing: NEVER commit private keys. The PUBLIC verify key IS committed
# (pinned at examples/keys/public.key) so devices can verify the signed origin.
private.key
*private*.key
# generated producer staging / origin scratch dirs (the committed origin lives at
# examples/catalog/ and is intentionally tracked)
staging/
origin/
*.bundle/
