# EdgeReco backend — environment configuration (EXAMPLE).
#
# Copy to `.env` and edit:    cp .env.example .env
# These are the SAFE DEFAULTS the code already uses — you only need to set a var
# to override it. Nothing here is a secret.
#
# How it's loaded: the recommender (`edgereco.config.Settings`, pydantic-settings)
# reads the EDGERECO_* vars from the PROCESS ENVIRONMENT. pydantic-settings does
# not auto-read this file, so export it before running, e.g.:
#     set -a && source .env && set +a
#     uv run edgereco serve ...
# The DEMO_* vars are read directly by the optional demo API server.

# ── EdgeReco recommender (edgereco.config.Settings, prefix EDGERECO_) ─────────

# Optional HTTP(S) URL of a remote catalog source. Empty = use a local catalog.
EDGERECO_CATALOG_URL=

# Local cache dir for the catalog + FAISS index (products.jsonl, vector/).
EDGERECO_CACHE_DIR=~/.edgereco

# Sentence-Transformers model id used to embed queries/products (Python runtime).
EDGERECO_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Default number of search results returned.
EDGERECO_SEARCH_LIMIT=10

# Reciprocal Rank Fusion constant k in 1/(k + rank). Higher = flatter fusion.
EDGERECO_RRF_K=60

# Host/port the FastAPI API binds to. 0.0.0.0 makes the demo container reachable
# from the host; use 127.0.0.1 to bind localhost-only.
EDGERECO_API_HOST=0.0.0.0
EDGERECO_API_PORT=8000

# ── Signed bundle sync (content-addressed catalog distribution) ──────────────
# Set BOTH base_url and verify_key_path to make `serve` sync + verify a signed
# bundle origin instead of reading a flat cache/index dir. A filesystem path
# (e.g. /tmp/origin or backend/examples/catalog) works as a base_url too.

# Bundle origin to sync from (HTTP(S) URL or local filesystem path). Empty = off.
EDGERECO_BUNDLE_BASE_URL=

# Path to the PUBLIC ed25519 verify key, pinned by the client (NOT the private
# key — never commit private keys). The committed example key:
EDGERECO_VERIFY_KEY_PATH=examples/keys/public.key

# Local dir where synced+verified bundle chunks are reassembled and cached.
EDGERECO_BUNDLE_CACHE_DIR=~/.edgereco/bundle

# ── Optional demo API server (demo_server.serve / demo_server.main) ──────────
# Only used by the OPTIONAL API-server use case (`uv run python -m demo_server.serve`);
# the headline Nimbus demo is backend-free and ignores these.

# Host/port the demo launcher binds to.
DEMO_HOST=127.0.0.1
DEMO_PORT=8000

# Comma-separated browser origins allowed by CORS. Empty = the localhost defaults
# (http://localhost:5173, http://localhost:4173). Set when serving the SPA from a
# non-localhost host (Docker edge / LAN).
DEMO_CORS_ORIGINS=
