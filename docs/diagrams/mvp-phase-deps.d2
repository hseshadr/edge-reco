direction: down

title: {
  label: MVP Phase Dependencies
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: false
  }
}

p1: "Phase 1\nProject Scaffolding & CI" {
  style.fill: "#e8f4f8"
  style.font-size: 13
}

p2: "Phase 2\nStorage Abstractions" {
  style.fill: "#e8f4f8"
  style.font-size: 13
}

p3: "Phase 3\nService Worker Shell" {
  style.fill: "#f0e8f8"
  style.font-size: 13
}

p4: "Phase 4\nManifest Manager" {
  style.fill: "#f0e8f8"
  style.font-size: 13
}

p5: "Phase 5\nWASM Engine Core (Rust)" {
  style.fill: "#e8f8e8"
  style.font-size: 13
}

p6: "Phase 6\nCompute Worker & SQLite" {
  style.fill: "#e8f8e8"
  style.font-size: 13
}

p7: "Phase 7\nHybrid Router & SDK API" {
  style.fill: "#f8f0e8"
  style.font-size: 13
}

p8: "Phase 8\nArtifact Distribution\n& Delta Sync" {
  style.fill: "#f0e8f8"
  style.font-size: 13
}

p9: "Phase 9\nEngine Hot-Swap\n& Smoke Test" {
  style.fill: "#f8e8e8"
  style.font-size: 13
}

p10: "Phase 10\nEvent System & Uplink" {
  style.fill: "#f8f0e8"
