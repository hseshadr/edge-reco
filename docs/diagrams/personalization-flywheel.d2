direction: right

a: User Interacts\nwith Recommendations {
  style.fill: "#e8f4f8"
}
b: Local State\nUpdated {
  style.fill: "#f0e8f8"
}
c: Better Local\nInference {
  style.fill: "#e8f8e8"
}
d: Server-Side\nTraining Pipeline {
  style.fill: "#f8f0e8"
}
e: New WASM\nEngine Published {
  style.fill: "#f8e8e8"
}
f: Client Downloads\nNew Engine {
  style.fill: "#e8e8f8"
}

a -> b: interaction events
b -> c: richer context
c -> a: better recs

b -> d: "anonymous events\nuplinked"
d -> e: improved model
e -> f: CDN deploy
f -> c
